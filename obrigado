<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FinançaPro - Compra Confirmada!</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,400;0,700;0,900;1,300;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --verde: #00C896;
    --verde-escuro: #00A67A;
    --preto: #0A0A0A;
    --cinza: #1A1A1A;
    --cinza-medio: #2A2A2A;
    --texto: #E8E8E0;
    --texto-suave: #9A9A8A;
    --ouro: #F5C842;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--preto);
    color: var(--texto);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 24px;
  }

  .check-circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(0,200,150,0.12);
    border: 2px solid rgba(0,200,150,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 32px;
    animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
  }

  .check-circle svg {
    width: 36px;
    height: 36px;
    stroke: var(--verde);
    stroke-width: 2.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .check-path {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: drawCheck 0.4s ease 0.4s forwards;
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0.5); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  .badge {
    display: inline-block;
    background: rgba(0,200,150,0.12);
    border: 1px solid rgba(0,200,150,0.3);
    color: var(--verde);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 18px;
    border-radius: 100px;
    margin-bottom: 24px;
    animation: fadeUp 0.5s ease 0.2s both;
  }

  h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -1.5px;
    text-align: center;
    max-width: 620px;
    margin: 0 auto 16px;
    animation: fadeUp 0.5s ease 0.3s both;
  }

  h1 em {
    font-style: italic;
    color: var(--verde);
  }

  .subtitulo {
    font-size: 1.05rem;
    color: var(--texto-suave);
    text-align: center;
    max-width: 480px;
    margin: 0 auto 56px;
    line-height: 1.7;
    animation: fadeUp 0.5s ease 0.4s both;
  }

  .passos {
    width: 100%;
    max-width: 560px;
    margin: 0 auto 48px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    animation: fadeUp 0.5s ease 0.5s both;
  }

  .passo {
    background: var(--cinza);
    padding: 24px 28px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
    border: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .passo:first-child { border-radius: 4px 4px 0 0; }
  .passo:last-child { border-radius: 0 0 4px 4px; }
  .passo:hover { border-color: rgba(0,200,150,0.15); }

  .passo-num {
    font-family: 'Fraunces', serif;
    font-size: 1.6rem;
    font-weight: 900;
    color: rgba(0,200,150,0.25);
    line-height: 1;
    flex-shrink: 0;
    min-width: 28px;
  }

  .passo-texto h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .passo-texto p {
    font-size: 0.88rem;
    color: var(--texto-suave);
    line-height: 1.5;
  }

  .divisor {
    width: 100%;
    max-width: 560px;
    height: 1px;
    background: var(--cinza-medio);
    margin: 0 auto 40px;
  }

  .compartilhar {
    text-align: center;
    max-width: 480px;
    margin: 0 auto 48px;
    animation: fadeUp 0.5s ease 0.6s both;
  }

  .compartilhar p {
    font-size: 0.95rem;
    color: var(--texto-suave);
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 14px 32px;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-whatsapp:hover {
    background: #1ebe5a;
    transform: translateY(-2px);
  }

  .btn-whatsapp svg {
    width: 20px;
    height: 20px;
    fill: #fff;
  }

  .suporte {
    text-align: center;
    animation: fadeUp 0.5s ease 0.7s both;
  }

  .suporte p {
    font-size: 0.85rem;
    color: var(--texto-suave);
    line-height: 1.7;
  }

  .suporte a {
    color: var(--verde);
    text-decoration: none;
  }

  .suporte a:hover { text-decoration: underline; }

  footer {
    margin-top: 64px;
    text-align: center;
    color: var(--texto-suave);
    font-size: 0.8rem;
  }

  footer strong { color: var(--verde); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    h1 { font-size: 2rem; }
    .passo { padding: 20px; }
  }
</style>
</head>
